{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OtoMusic",
  "version": "0.1.0",
  "identifier": "com.otomusic.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OtoMusic",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
