{
  "name": "otomusic",
  "private": true,
  "version": "1.0.4",
  "description": "OtoMusic desktop player for Navidrome/Subsonic libraries.",
  "author": {
    "name": "Aloys23",
    "email": "aloys233@gmail.com"
  },
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.otomusic.app",
    "productName": "OtoMusic",
    "directories": {
      "buildResources": "electron/assets",
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/assets/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/assets/icon.png",
        "to": "tray/icon.png"
      }
    ],
    "asar": true,
    "linux": {
      "category": "AudioVideo",
      "maintainer": "Aloys23 <aloys233@gmail.com>"
    }
  },
  "scripts": {
    "dev": "vite --host --port 1420 --config vite.config.ts",
    "dev:web": "vite --host --port 1420 --mode web --config vite.config.ts",
    "build": "tsc -b && vite build --config vite.config.ts",
    "build:desktop": "pnpm build && electron-builder",
    "check": "pnpm typecheck && pnpm build",
    "preview": "vite preview --host --port 1420 --config vite.config.ts",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "spark-md5": "^3.0.2",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
